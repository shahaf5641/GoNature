<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane fx:id="updateParametersRootPane" prefHeight="424.0" prefWidth="1094.0" stylesheets="@../resources/projectTheme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <VBox alignment="CENTER" layoutX="-1.0" prefHeight="424.0" prefWidth="1094.0" spacing="10.0">
        <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
        </padding>
        <Label fx:id="headerLabel" alignment="CENTER" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="Update Parameters" />
        <Accordion fx:id="accordion" prefWidth="600.0">
            <panes>
                <TitledPane fx:id="estimatedTimeTP" animated="false" contentDisplay="CENTER" style="-fx-font-size: 16px;" text="Estimated Stay Time Settings">
                    <content>
                        <VBox alignment="CENTER" spacing="10.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                            <TextField fx:id="newEsitimatedTIme" prefWidth="300.0" promptText="Enter New Estimated Stay Time" />
                        </VBox>
                    </content>
                </TitledPane>
                <TitledPane fx:id="gapTP" animated="false" style="-fx-font-size: 16px;" text="Gap Settings">
                    <content>
                        <VBox alignment="CENTER" spacing="10.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                            <TextField fx:id="gapTextField" prefWidth="300.0" promptText="Enter New Gap" />
                        </VBox>
                    </content>
                </TitledPane>
                <TitledPane fx:id="maxVisitorsTP" animated="false" contentDisplay="CENTER" expanded="false" style="-fx-font-size: 16px;" text="Maximum Visitors Settings">
                    <content>
                        <VBox alignment="CENTER" spacing="10.0">
                            <padding>
                                <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
                            </padding>
                            <TextField fx:id="newMaxVisitorsTextField" prefWidth="300.0" promptText="Enter New Maximum Visitors" />
                        </VBox>
                    </content>
                </TitledPane>
            </panes>
         <VBox.margin>
            <Insets right="50.0" top="10.0" />
         </VBox.margin>
         <padding>
            <Insets right="5.0" />
         </padding>
        </Accordion>
        <Button fx:id="sendForApprovealButton" prefHeight="43.0" prefWidth="202.0" text="Send for Approval" />
    </VBox>
</AnchorPane>
