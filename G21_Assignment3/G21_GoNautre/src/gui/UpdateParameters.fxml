<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Accordion?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane fx:id="updateParametersRootPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" stylesheets="@../resources/projectTheme.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1">
    <padding>
        <javafx.geometry.Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
    </padding>
    <children>
        <Accordion fx:id="accordion" layoutX="185.0" layoutY="97.0" prefHeight="439.0" prefWidth="531.0">
            <panes>
                <TitledPane fx:id="maxVisitorsTP" animated="false" expanded="false" text="UPDATE MAX VISITORS">
                    <content>
                        <AnchorPane fx:id="identificationAP" minHeight="0.0" minWidth="0.0" prefHeight="194.0" prefWidth="529.0">
                            <children>
                                <TextField fx:id="newMaxVisitorsTextField" alignment="CENTER" layoutX="145.0" layoutY="156.0" prefHeight="37.0" prefWidth="239.0" promptText="Enter New Max Visitors" />
                                <Label layoutX="203.0" layoutY="29.0" prefHeight="39.0" prefWidth="124.0" text="Enter Max Visitors" />
                            </children>
                        </AnchorPane>
                    </content>
                </TitledPane>
                <TitledPane fx:id="estimatedTimeTP" animated="false" text="UPDATE ESTIMATED STAY TIME">
                    <content>
                        <AnchorPane fx:id="informationAP" minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0">
                            <children>
                                <TextField fx:id="newEsitimatedTIme" alignment="CENTER" layoutX="145.0" layoutY="129.0" prefHeight="37.0" prefWidth="239.0" promptText="Enter New Estimated Stay Time" />
                                <Label layoutX="188.0" layoutY="57.0" text="Enter Estimated Stay Time" />
                            </children>
                        </AnchorPane>
                    </content>
                </TitledPane>
                <TitledPane fx:id="gapTP" animated="false" text="UPDATE GAP">
                    <content>
                        <AnchorPane fx:id="paymentAP" minHeight="0.0" minWidth="0.0" prefHeight="180.0" prefWidth="200.0" visible="false">
                            <children>
                                <TextField fx:id="gapTextField" alignment="CENTER" layoutX="145.0" layoutY="156.0" prefHeight="37.0" prefWidth="239.0" promptText="Enter New Gap" />
                                <Label layoutX="234.0" layoutY="55.0" text="Enter Gap:" />
                            </children>
                        </AnchorPane>
                    </content>
                </TitledPane>
            </panes>
        </Accordion>
        <Label fx:id="headerLabel" layoutX="337.0" layoutY="22.0" text="Update Parameters" />
        <Button fx:id="sendForApprovealButton" layoutX="360.0" layoutY="547.0" onAction="#sendForApprovealButtonClicked" text="SEND FOR APPROVAL" />
    </children>
</AnchorPane>
